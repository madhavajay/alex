{
  "id": "alex.fable-5-to-gpt-5.6-sol",
  "name": "Fable 5 → GPT-5.6 Sol",
  "description": "On Anthropic HTTP 529 overloaded_error, retry with high-effort GPT-5.6 Sol.",
  "enabled": true,
  "priority": 100,
  "hook": "attempt_result",
  "capabilities": ["attempt.read_error_body", "route.override"],
  "when": {
    "models": ["claude-fable-5"],
    "providers": ["anthropic"],
    "status": [529],
    "error_classes": ["capacity"],
    "body_contains_any": ["overloaded_error"]
  },
  "then": {
    "reroute": {
      "model": "gpt-5.6-sol",
      "providers": ["openai"],
      "provider_mode": "only",
      "scope": "request",
      "effort": "high",
      "reason": "Fable 5 returned Anthropic's overloaded_error; retrying with GPT-5.6 Sol",
      "max_attempts": 3
    }
  }
}
