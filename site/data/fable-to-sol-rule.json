{
  "id": "alex.fable-5-to-gpt-5.6-sol",
  "name": "Fable 5 → GPT-5.6 Sol",
  "description": "If Fable 5 fails with a capacity or provider error, retry with GPT-5.6 Sol.",
  "enabled": true,
  "priority": 100,
  "hook": "attempt_result",
  "capabilities": ["route.override"],
  "when": {
    "models": ["claude-fable-5"],
    "providers": ["anthropic"],
    "status": [429, "500-599"],
    "error_classes": ["capacity", "server"]
  },
  "then": {
    "reroute": {
      "model": "gpt-5.6-sol",
      "providers": ["openai"],
      "provider_mode": "only",
      "scope": "request",
      "reason": "Fable 5 failed; retrying with GPT-5.6 Sol",
      "max_attempts": 3
    }
  }
}
