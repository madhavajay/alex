class Alex < Formula
  desc "Local LLM subscription router: credential vault, proxy, trace capture"
  homepage "https://github.com/madhavajay/alex"
  version "{{VERSION}}"
  license any_of: ["MIT", "Apache-2.0"]

  on_macos do
    on_arm do
      url "https://github.com/madhavajay/alex/releases/download/v{{VERSION}}/alex-cli-{{VERSION}}-macos-aarch64.tar.gz"
      sha256 "{{SHA_MAC_ARM}}"
    end

    on_intel do
      url "https://github.com/madhavajay/alex/releases/download/v{{VERSION}}/alex-cli-{{VERSION}}-macos-x86_64.tar.gz"
      sha256 "{{SHA_MAC_INTEL}}"
    end
  end

  on_linux do
    on_intel do
      url "https://github.com/madhavajay/alex/releases/download/v{{VERSION}}/alex-cli-{{VERSION}}-linux-x86_64.tar.gz"
      sha256 "{{SHA_LINUX}}"
    end
  end

  def install
    bin.install "alex"
  end

  livecheck do
    url :stable
    strategy :github_latest
  end

  test do
    assert_match version.to_s, shell_output("#{bin}/alex --version")
  end
end
