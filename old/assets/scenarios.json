      },
      {
        "id": "configure-pi",
        "label": "Connect Pi to Alex",
        "detail": "alex connect pi installs the scoped local route",
        "kind": "route"
      },
      {
        "id": "request",
        "label": "Pi asks for Opus 4.8",
        "detail": "pi --model alex/claude-opus-4-8 -p “Review this”",
        "kind": "request"
      },
      {
        "id": "dario",
        "label": "Alex selects the subscription path",
        "detail": "Non-Claude-Code Anthropic traffic is routed through Dario",
        "kind": "decision"
      },
      {
        "id": "proof",
        "label": "The trace proves where it ran",
        "detail": "Pi · Anthropic · Opus 4.8 · subscription identity · Dario",
