        "failure_fixture": "982990ef2c01cb38297933bbaf26b97305f4decd12984aee5acf08338812b573",
        "rule": "baeb2f9712e7cee4bcae3f8af59a63d747f8421f9003a7e697ea3b9e3024e000",
        "rule_builtin": "3d1d0859ae3f9e5b87aa739ad18137c183f9a2a6e07200ca05a8875ae21ae95a"
