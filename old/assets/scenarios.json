    "rule": {
      "id": "example.fable-overload-to-sol",
      "name": "Move overloaded Fable chats to Sol",
      "description": "Reroute selected failed Anthropic Fable requests to OpenAI Sol.",
      "enabled": true,
      "priority": 100,
      "hook": "attempt_result",
      "capabilities": [
        "attempt.read_error_body",
        "route.override",
        "session.pin",
        "response.prepend_text"
      ],
      "when": {
        "harness_names": [
          "claude",
          "codex",
          "pi"
        ],
        "models": [
          "claude-fable-5",
          "fable-*"
        ],
        "providers": [
          "anthropic"
        ],
        "status": [
          429,
          "500-599"
        ],
        "error_classes": [
          "capacity",
          "server"
        ],
        "body_contains_any": [
          "model is currently overloaded",
          "subscription is unavailable"
        ]
      },
      "then": {
        "reroute": {
          "model": "gpt-5.6-sol",
          "providers": [
            "openai"
          ],
          "provider_mode": "only",
          "scope": "session",
          "ttl_seconds": 86400,
          "notice": "We moved this chat from Fable 5 to GPT 5.6 Sol.",
          "reason": "Fable failed with a selected overload or availability error",
          "max_attempts": 3,
          "required_capabilities": {
            "portable_history": true
          }
        }
      }
    }
  },
  {
    "schema_version": 1,
    "id": "ask-another-model",
    "title": "Keep the first answer. Ask a second model.",
    "description": "A captured Claude session is reconstructed in Pi with Sol 5.6. Alex records the explicit cross-harness fork so the original and independent answer remain connected without pretending they were one model.",
    "steps": [
      {
        "id": "source",
        "label": "Claude produces the first answer",
        "detail": "The source turn is captured with its model and account provenance",
        "kind": "request"
      },
      {
        "id": "ask",
        "label": "Ask for an independent opinion",
        "detail": "alex resume session-42 pi --model alex/gpt-5.6-sol",
        "kind": "decision"
      },
      {
        "id": "history",
        "label": "Alex reconstructs the verified history",
        "detail": "The target receives the prior conversation in provider-native order",
        "kind": "route"
      },
      {
        "id": "second",
        "label": "Sol 5.6 answers in Pi",
        "detail": "The second subscription produces a separately attributed turn",
        "kind": "route"
      },
      {
        "id": "lineage",
        "label": "Both answers remain in one lineage",
        "detail": "The target records its source session, harness, model, and fork time",
        "kind": "success"
      }
    ],
    "source": {
      "harness": "claude",
      "session_id": "session-42",
      "model": "claude-opus-4-8"
    },
    "target": {
      "harness": "pi",
      "model": "gpt-5.6-sol",
      "forked_from_session_id": "session-42",
      "forked_from_harness": "claude"
    },
    "source_contracts": [
      "Fork a captured session into a new interactive harness session",
      "record_session_fork",
      "forked_from_session_id",
      "forked_from_harness",
      "transcript_first_fork_request_renders_inherited_history_in_order"
