{
  "version": 1,
  "description": "Declarative harness/model defaults and routing notes used to keep Alexandria harness smoke runs consistent.",
  "models": {
    "gpt-5.5": {
      "provider": "openai-subscription",
      "proxy_route": "codex",
      "endpoint": "openai-responses"
    },
    "openai/gpt-5.5": {
      "provider": "openai-subscription",
      "proxy_route": "codex",
      "endpoint": "openai-chat-completions",
      "notes": "OpenAI-compatible harnesses usually expect a provider prefix for LiteLLM or native provider selection."
    },
    "alexandria/gpt-5.5": {
      "provider": "alexandria-proxy",
      "proxy_route": "codex",
      "endpoint": "openai-chat-completions",
      "notes": "Alexandria proxy model alias for OpenAI-compatible harnesses."
    },
    "claude-opus-4-8": {
      "provider": "claude-subscription",
      "proxy_route": "dario",
      "endpoint": "anthropic-messages"
    },
    "claude/claude-opus-4-8": {
      "provider": "claude-subscription",
      "proxy_route": "dario",
      "endpoint": "openai-chat-completions-to-anthropic",
      "notes": "Use for OpenAI-compatible harnesses routed through an Anthropic-compatible bridge."
    },
    "alexandria/opus-4.8": {
      "provider": "alexandria-proxy",
      "proxy_route": "dario",
      "endpoint": "openai-chat-completions-to-anthropic",
      "notes": "Alexandria proxy model alias for OpenAI-compatible harnesses."
    },
    "claude-sonnet-5": {
      "provider": "claude-subscription",
      "proxy_route": "dario",
      "endpoint": "anthropic-messages"
    },
    "claude/claude-sonnet-5": {
      "provider": "claude-subscription",
      "proxy_route": "dario",
      "endpoint": "openai-chat-completions-to-anthropic",
      "notes": "Use for OpenAI-compatible harnesses routed through an Anthropic-compatible bridge."
    },
    "amp/default": {
      "provider": "amp-native"
    },
    "cursor/composer-2.5": {
      "provider": "cursor-native"
    },
    "factory/default": {
      "provider": "factory-native"
    },
    "grok-code-fast-1": {
      "provider": "grok-native",
      "notes": "xAI API alias for grok-build-0.1; older default kept as an explicit model."
    },
    "grok-build": {
      "provider": "grok-native",
      "notes": "Grok CLI model cache alias for Grok Build."
    },
    "grok-composer-2.5-fast": {
      "provider": "grok-native"
    }
  },
  "harnesses": {
    "claude": {
      "aliases": ["claude-code"],
      "default_model": "claude-opus-4-8",
      "model_env": ["CLAUDE_MODEL"],
      "version_env": "CLAUDE_CODE_VERSION",
      "default_version": "2.1.202",
      "proxy_supported": true,
      "proxy_mode": "anthropic-native-or-codex-bridge",
      "source": {
        "mode": "package artifact from local source",
        "env": "CLAUDE_CODE_REPO",
        "default_path": "repos/claude-code"
      },
      "system_prompt_policy": "preserve native prompt; prefer append/custom instructions only when the harness supports it"
    },
    "codex": {
      "aliases": [],
      "default_model": "gpt-5.5",
      "model_env": ["CODEX_MODEL"],
      "proxy_supported": true,
      "proxy_mode": "openai-native",
      "source": {
        "mode": "registered source checkout",
        "env": "CODEX_REPO",
        "default_path": "repos/codex"
      }
    },
    "pi": {
      "aliases": [],
      "default_model": "openai/gpt-5.5",
      "non_proxy_default_model": "openai-codex/gpt-5.5",
      "model_env": ["PI_MODEL"],
      "version_env": "PI_VERSION",
      "default_version": "0.80.3",
      "proxy_supported": true,
      "proxy_mode": "openai-compatible",
      "source": {
        "mode": "package artifact from local source",
        "env": "PI_REPO",
        "default_path": "repos/pi"
      }
    },
    "oh-my-pi": {
      "aliases": ["omp"],
      "default_model": "openai/gpt-5.5",
      "model_env": ["OH_MY_PI_MODEL"],
      "version_env": "OH_MY_PI_VERSION",
      "default_version": "16.3.11",
      "runtime_versions": {
        "bun": {
          "env": "OH_MY_PI_BUN_VERSION",
          "default_version": "1.3.14"
        }
      },
      "proxy_supported": true,
      "proxy_mode": "openai-compatible",
      "source": {
        "mode": "registered source checkout",
        "env": "OH_MY_PI_REPO",
        "default_path": "repos/oh-my-pi"
      },
      "notes": "Uses the @oh-my-pi/pi-coding-agent omp CLI with generated models.yml for proxy routing."
    },
    "opencode": {
      "aliases": [],
      "default_model": "openai/gpt-5.5",
      "model_env": ["OPENCODE_MODEL"],
      "version_env": "OPENCODE_VERSION",
      "default_version": "1.17.14",
      "proxy_supported": true,
      "proxy_mode": "openai-compatible",
      "source": {
        "mode": "registered source checkout",
        "env": "OPENCODE_REPO",
        "default_path": "repos/opencode"
      }
    },
    "mini-swe-agent": {
      "aliases": ["mini"],
      "default_model": "openai/gpt-5.5",
      "model_env": ["MINI_SWE_AGENT_MODEL"],
      "proxy_supported": true,
      "proxy_mode": "litellm-openai-compatible",
      "source": {
        "mode": "mounted local source",
        "env": "MINI_SWE_AGENT_REPO",
        "default_path": "repos/mini-swe-agent"
      }
    },
    "kimi-code": {
      "aliases": ["kimi"],
      "default_model": "openai/gpt-5.5",
      "model_env": ["KIMI_CODE_MODEL"],
      "proxy_supported": true,
      "proxy_mode": "openai-compatible",
      "source": {
        "mode": "mounted local source",
        "env": "KIMI_CODE_REPO",
        "default_path": "repos/kimi-code"
      }
    },
    "gemini-cli": {
      "aliases": ["gemini"],
      "default_model": "openai/gpt-5.5",
      "model_env": ["GEMINI_CLI_MODEL"],
      "proxy_supported": true,
      "proxy_mode": "gemini-gateway-to-openai-compatible",
      "source": {
        "mode": "mounted local source",
        "env": "GEMINI_CLI_REPO",
        "default_path": "repos/gemini-cli"
      }
    },
    "qwen-code": {
      "aliases": ["qwen"],
      "default_model": "openai/gpt-5.5",
      "model_env": ["QWEN_CODE_MODEL"],
      "version_env": "QWEN_CODE_PACKAGE",
      "default_version": "@qwen-code/qwen-code@0.19.3",
      "proxy_supported": true,
      "proxy_mode": "openai-compatible"
    },
    "goose": {
      "aliases": [],
      "default_model": "openai/gpt-5.5",
      "model_env": ["GOOSE_MODEL"],
      "version_env": "GOOSE_VERSION",
      "default_version": "1.41.0",
      "proxy_supported": true,
      "proxy_mode": "openai-compatible"
    },
    "opensage-adk": {
      "aliases": ["opensage"],
      "default_model": "openai/gpt-5.5",
      "model_env": ["OPENSAGE_ADK_MODEL"],
      "proxy_supported": true,
      "proxy_mode": "litellm-openai-compatible",
      "source": {
        "mode": "mounted local source",
        "env": "OPENSAGE_ADK_REPO",
        "default_path": "repos/opensage-adk"
      }
    },
    "pydantic-ai-harness": {
      "aliases": ["pydantic-ai"],
      "default_model": "openai/gpt-5.5",
      "model_env": ["PYDANTIC_AI_HARNESS_MODEL"],
      "proxy_supported": true,
      "proxy_mode": "openai-compatible",
      "source": {
        "mode": "mounted local source",
        "env": "PYDANTIC_AI_HARNESS_REPO",
        "default_path": "repos/pydantic-ai-harness"
      }
    },
    "stirrup": {
      "aliases": [],
      "default_model": "openai/gpt-5.5",
      "model_env": ["STIRRUP_MODEL"],
      "proxy_supported": true,
      "proxy_mode": "openai-compatible",
      "source": {
        "mode": "mounted local source",
        "env": "STIRRUP_REPO",
        "default_path": "repos/Stirrup"
      }
    },
    "jcode": {
      "aliases": [],
      "default_model": "openai/gpt-5.5",
      "model_env": ["JCODE_TB_MODEL"],
      "version_env": "JCODE_HARBOR_VERSION",
      "default_version": "v0.36.0",
      "proxy_supported": true,
      "proxy_mode": "openai-compatible"
    },
    "cursor-cli": {
      "aliases": ["cursor"],
      "default_model": "composer-2.5",
      "model_env": ["CURSOR_MODEL"],
      "enabled": false,
      "proxy_supported": false,
      "proxy_mode": "native-only",
      "notes": "Disabled from --harness all unless Cursor native auth is configured; imports ~/.cursor CLI config/state."
    },
    "amp-code": {
      "aliases": ["amp"],
      "default_model": "amp/default",
      "model_env": ["AMP_MODEL"],
      "version_env": "AMP_VERSION",
      "default_version": "0.0.1783383739-g931303",
      "enabled": false,
      "proxy_supported": true,
      "proxy_mode": "amp-url-wrap",
      "notes": "Use `alex auth import amp` for billing + `alex wrap env amp` for AMP_URL capture. Full stream dump needs HTTPS_PROXY wrap (see alex-wrap). Actor protocol reroute still experimental."
    },
    "droid-cli": {
      "aliases": ["droid"],
      "default_model": "gpt-5.5",
      "non_proxy_default_model": "factory/default",
      "model_env": ["DROID_MODEL"],
      "proxy_supported": true,
      "proxy_mode": "openai-compatible",
      "version_policy": "Factory install script controlled by DROID_INSTALL_COMMAND; no public npm package pin found."
    },
    "grok-build": {
      "aliases": ["grok"],
      "default_model": "gpt-5.5",
      "non_proxy_default_model": "grok-build",
      "model_env": ["GROK_MODEL"],
      "version_env": "GROK_CLIENT_VERSION",
      "default_version": "0.2.77",
      "proxy_supported": true,
      "proxy_mode": "openai-compatible",
      "current_version": "0.2.77",
      "notes": "Uses the xAI Grok CLI (`agent`, falling back to `grok`) with XAI_API_KEY or imported ~/.grok auth."
    },
    "hermes": {
      "aliases": ["hermes-agent"],
      "default_model": "alexandria/gpt-5.5",
      "model_env": ["HERMES_MODEL"],
      "version_env": "HERMES_VERSION",
      "default_version": "main",
      "commit_env": "HERMES_COMMIT",
      "default_commit": "88d1d6206f399c134d1f4c0b7db27733aaa3c50c",
      "proxy_supported": true,
      "proxy_mode": "litellm-openai-compatible"
    },
    "oracle": {
      "aliases": [],
      "default_model": null,
      "model_env": [],
      "proxy_supported": false,
      "proxy_mode": "none"
    }
  }
}
