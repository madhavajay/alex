{
  "model": "claude-sonnet-4-5",
  "system": "You are a coding assistant.",
  "messages": [
    {"role": "user", "content": "Inspect the failing test."},
    {
      "role": "assistant",
      "content": [
        {"type": "text", "text": "I will inspect it."},
        {
          "type": "tool_use",
          "id": "tool-1",
          "name": "read_file",
          "input": {"path": "src/lib.rs"}
        }
      ]
    },
    {
      "role": "user",
      "content": [
        {
          "type": "tool_result",
          "tool_use_id": "tool-1",
          "content": "fn broken() {}"
        }
      ]
    },
    {"role": "assistant", "content": "The failure is in broken()."},
    {"role": "user", "content": "Fix it and run the tests."}
  ]
}
