{
  "schema_version": 1,
  "preset_id": "example.fable-overload-to-sol",
  "shared_site_scenario": "fable-to-sol-vector.json",
  "cases": [
    {
      "id": "overload-reroute-and-lease",
      "failure_fixture": "anthropic-fable-unavailable-529",
      "accounts": ["anthropic", "openai"],
      "expected": {
        "decision": "reroute",
        "provider": "openai",
        "model": "gpt-5.6-sol",
        "status": 200,
        "lease": "active",
        "explanation_contains": "Fable failed with a selected overload or availability error"
      }
    },
    {
      "id": "recovery-returns-after-lease-expiry",
      "setup": "expire the session lease after Anthropic recovers",
      "accounts": ["anthropic", "openai"],
      "expected": {
        "decision": "return_requested_route",
        "provider": "anthropic",
        "model": "claude-fable-5",
        "status": 200,
        "lease": "expired",
        "explanation_contains": "lease expired, so Alex returned this request"
      }
    },
    {
      "id": "non-matching-error-is-returned",
      "failure_fixture": "anthropic-fable-nonmatching-500",
      "accounts": ["anthropic", "openai"],
      "expected": {
        "decision": "continue",
        "provider": "anthropic",
        "model": "claude-fable-5",
        "status": 500,
        "lease": "none",
        "explanation_contains": "did not match this attempt"
      }
    },
    {
      "id": "unavailable-fallback-account-returns-original",
      "failure_fixture": "anthropic-fable-unavailable-529",
      "accounts": ["anthropic"],
      "expected": {
        "decision": "reroute_unavailable",
        "provider": "anthropic",
        "model": "claude-fable-5",
        "status": 529,
        "lease": "none",
        "explanation_contains": "no eligible openai account could serve gpt-5.6-sol"
      }
    }
  ]
}
